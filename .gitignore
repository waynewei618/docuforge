# Python/runtime caches
__pycache__/
*.py[cod]
.pytest_cache/

# Local environment and secrets
.env
.env.*
*.key

# Local workflow state, intermediate files, and generated deliverables
workflows/arxiv_translation/tmp/
workflows/arxiv_translation/output/
workflows/manuscript_to_ppt/tmp/
workflows/thesis_workspace/literature_review/output/*
!workflows/thesis_workspace/literature_review/output/.gitkeep
workflows/thesis_workspace/proposal/output/*
!workflows/thesis_workspace/proposal/output/.gitkeep
outputs/

# Local paper corpus and translated PDFs
/papers/

# LaTeX build byproducts that may appear outside tmp/
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv

# OS/editor noise
.DS_Store
Thumbs.db
